# ============================================================
#  Bu dosyayı ".env" olarak kopyala ve kendi key'lerini gir:
#    cp .env.example .env
# ============================================================

# TMDB — film/dizi önerileri için GEREKLİ (ücretsiz)
# Key al: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Groq — akıllı sohbet/öneri için ÖNERİLEN (ücretsiz, kart istemez)
# Her kullanıcı KENDİ key'ini almalı (günlük token limiti kişiye özel).
# Key al: https://console.groq.com/keys
# (Boş bırakırsan uygulama yine çalışır, sadece daha basit keyword tabanlı öneri yapar.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# OMDb — IMDb puanı zenginleştirme (opsiyonel, ücretsiz)
# Key al: https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# Spotify — müzik önerileri (opsiyonel)
# App oluştur: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# LM Studio — yerel LLM (opsiyonel, Groq yerine bilgisayarında model çalıştırmak istersen)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model
