# TMDB API (required for live movie/series recommendations)
# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# OMDb API (optional, enriches ratings via IMDb data)
# Get a free key at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# Spotify API (optional, enables music recommendations)
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional cloud LLM provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional LM Studio local server
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model
